

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}
model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  chats Chats[]
}

model Chats {
  id       Int    @id @default(autoincrement())
  content  String
  author   User   @relation(fields: [authorId], references: [id])
  authorId Int
}
